<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@drawable/bg_card"
        android:padding="14dp">
        <EditText android:id="@+id/etCaption" android:layout_width="match_parent"
            android:layout_height="56dp" android:background="@drawable/bg_input"
            android:hint="@string/caption" android:padding="12dp"
            android:textColor="@color/text" android:textColorHint="@color/muted"/>
        <Button android:id="@+id/btnPick" android:layout_width="match_parent"
            android:layout_height="56dp" android:background="@drawable/bg_btn_primary"
            android:text="@string/add_photo" android:textColor="@color/text"
            android:textStyle="bold" android:layout_marginTop="10dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPhotos"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="12dp"/>
</LinearLayout>
