<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_card"
    android:padding="10dp" android:layout_marginBottom="10dp">
    <ImageView android:id="@+id/img" android:layout_width="match_parent"
        android:layout_height="200dp" android:scaleType="centerCrop"/>
    <TextView android:id="@+id/tvCaption" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:padding="8dp"
        android:textColor="@color/text" android:textSize="15sp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tvDate" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:padding="8dp" android:textColor="@color/muted" android:textSize="12sp"/>
        <Button android:id="@+id/btnDel" android:layout_width="wrap_content"
            android:layout_height="40dp" android:text="@string/delete"
            android:textColor="@color/destructive"
            android:background="@android:color/transparent"/>
    </LinearLayout>
</LinearLayout>
