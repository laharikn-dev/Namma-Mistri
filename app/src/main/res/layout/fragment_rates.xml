<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:background="@drawable/bg_card" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/rate_brick" android:textColor="@color/text"/>
        <EditText android:id="@+id/etBrick" android:layout_width="match_parent"
            android:layout_height="56dp" android:background="@drawable/bg_input"
            android:padding="12dp" android:inputType="numberDecimal"
            android:textColor="@color/text" android:layout_marginTop="6dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/rate_cement" android:textColor="@color/text"
            android:layout_marginTop="14dp"/>
        <EditText android:id="@+id/etCement" android:layout_width="match_parent"
            android:layout_height="56dp" android:background="@drawable/bg_input"
            android:padding="12dp" android:inputType="numberDecimal"
            android:textColor="@color/text" android:layout_marginTop="6dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/rate_sand" android:textColor="@color/text"
            android:layout_marginTop="14dp"/>
        <EditText android:id="@+id/etSand" android:layout_width="match_parent"
            android:layout_height="56dp" android:background="@drawable/bg_input"
            android:padding="12dp" android:inputType="numberDecimal"
            android:textColor="@color/text" android:layout_marginTop="6dp"/>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent"
            android:layout_height="60dp" android:background="@drawable/bg_btn_primary"
            android:text="@string/save" android:textColor="@color/text"
            android:textStyle="bold" android:textSize="18sp"
            android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>
